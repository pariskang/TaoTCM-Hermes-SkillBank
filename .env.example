# LiteLLM annotation (Azure OpenAI example).
# Leave LITELLM_MODEL empty to run the deterministic heuristic pipeline offline.
LITELLM_MODEL=azure/gpt-4o
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-08-01-preview

# Set to 0 to force heuristic mode even when LITELLM_MODEL is configured.
TAOTCM_USE_LLM=1

MAX_CONCURRENCY=5
MAX_RETRIES=4
CHUNK_CHARS=3500
DEFAULT_LANGUAGE=zh
OUTPUT_DIR=outputs
SQLITE_PATH=outputs/progress.sqlite
